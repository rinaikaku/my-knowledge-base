{
  "$schema": "../_schema.json",
  "element": "equation",
  "shared_base": true,
  "properties": {
    "formula": {
      "type": "string",
      "description": "math expression. Aliases: text.",
      "aliases": [
        "text"
      ],
      "add": true,
      "set": true,
      "get": false,
      "examples": [
        "--prop formula=\"x^2 + y^2 = z^2\""
      ],
      "readback": "n/a in the shared base. pptx overrides to get:true (LaTeX reconstructed from <m:oMath>); docx does not surface a formula key on Get.",
      "enforcement": "report"
    }
  }
}
